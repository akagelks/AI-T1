import pandas as pd
import numpy as np

def rodar_backtest(
    df: pd.DataFrame, 
    nome_estrategia: str, 
    capital_inicial: float,
    filtro_regime: bool = True
) -> dict:
    """
    Motor de backtest institucional.
    Retorna: trades (lista), equity_curve (Series), metricas (dict)
    """
    from src.strategies import ESTRATEGIAS, gerar_sinais
    
    params = ESTRATEGIAS[nome_estrategia]
    sinais = gerar_sinais(df, nome_estrategia)
    
    # Aplica filtro de regime se disponível
    if filtro_regime and 'acima_ema' in df.columns:
        if params['tipo'] == 'LONG':
            sinais = sinais & df['acima_ema']
        else:
            sinais = sinais & ~df['acima_ema']
    
    trades = []
    capital = capital_inicial
    equity = []
    posicao_aberta = False
    cooldown = 0
    
    for i in range(50, len(df)):  # Começa após 50 candles para indicadores
        candle = df.iloc[i]
        timestamp = df.index[i]
        
        # Cooldown: espera 3 candles após fechar trade
        if cooldown > 0:
            cooldown -= 1
            equity.append(capital)
            continue
        
        # Entrada
        if sinais.iloc[i] and not posicao_aberta:
            preco_entrada = candle['close']
            if params['tipo'] == 'LONG':
                tp = preco_entrada * (1 + params['tp_pct']/100)
                sl = preco_entrada * (1 - params['sl_pct']/100)
            else:  # SHORT
                tp = preco_entrada * (1 - params['tp_pct']/100)
                sl = preco_entrada * (1 + params['sl_pct']/100)
            
            tamanho = capital * 0.95
            quantidade = tamanho / preco_entrada
            taxa_entrada = tamanho * 0.001
            
            posicao_aberta = True
            trade = {
                'timestamp_entrada': timestamp,
                'preco_entrada': preco_entrada,
                'tp': tp,
                'sl': sl,
                'quantidade': quantidade,
                'taxa_entrada': taxa_entrada,
                'tipo': params['tipo'],
                'estrategia': nome_estrategia
            }
        
        # Saída
        if posicao_aberta:
            resultado = None
            preco_saida = None
            
            if params['tipo'] == 'LONG':
                if candle['high'] >= tp:
                    resultado = 'WIN'
                    preco_saida = tp
                elif candle['low'] <= sl:
                    resultado = 'LOSS'
                    preco_saida = sl
            else:  # SHORT
                if candle['low'] <= tp:
                    resultado = 'WIN'
                    preco_saida = tp
                elif candle['high'] >= sl:
                    resultado = 'LOSS'
                    preco_saida = sl
            
            if resultado:
                valor_saida = trade['quantidade'] * preco_saida
                taxa_saida = valor_saida * 0.001
                
                if params['tipo'] == 'LONG':
                    pnl = (preco_saida - trade['preco_entrada']) * trade['quantidade']
                else:
                    pnl = (trade['preco_entrada'] - preco_saida) * trade['quantidade']
                
                pnl_liquido = pnl - trade['taxa_entrada'] - taxa_saida
                capital += pnl_liquido
                
                trade.update({
                    'timestamp_saida': timestamp,
                    'preco_saida': preco_saida,
                    'resultado': resultado,
                    'pnl_liquido': pnl_liquido,
                    'capital_final': capital
                })
                trades.append(trade)
                posicao_aberta = False
                cooldown = 3  # 3 candles de resfriamento
        
        equity.append(capital)
    
    # Calcula métricas institucionais
    metricas = calcular_metricas(trades, capital_inicial, equity)
    
    return {
        'trades': trades,
        'equity': equity,
        'metricas': metricas
    }

def calcular_metricas(trades: list, capital_inicial: float, equity: list) -> dict:
    """Calcula métricas de risco no estilo institucional."""
    if not trades:
        return {
            'roi_pct': 0, 'win_rate': 0, 'profit_factor': 0,
            'max_drawdown_pct': 0, 'total_trades': 0, 'lucro_liquido': 0
        }
    
    df_trades = pd.DataFrame(trades)
    wins = df_trades[df_trades['resultado'] == 'WIN']['pnl_liquido'].sum()
    losses = abs(df_trades[df_trades['resultado'] == 'LOSS']['pnl_liquido'].sum())
    
    # Profit Factor
    profit_factor = wins / losses if losses > 0 else wins
    
    # Max Drawdown
    equity_series = pd.Series([capital_inicial] + equity)
    running_max = equity_series.cummax()
    drawdown = (equity_series - running_max) / running_max
    max_drawdown = drawdown.min() * 100
    
    # ROI
    capital_final = equity[-1] if equity else capital_inicial
    roi = ((capital_final - capital_inicial) / capital_inicial) * 100
    
    return {
        'roi_pct': roi,
        'win_rate': (len(df_trades[df_trades['resultado'] == 'WIN']) / len(df_trades)) * 100,
        'profit_factor': profit_factor,
        'max_drawdown_pct': max_drawdown,
        'total_trades': len(df_trades),
        'lucro_liquido': capital_final - capital_inicial,
        'capital_final': capital_final
    }